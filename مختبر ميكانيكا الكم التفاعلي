<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مختبر ميكانيكا الكم التفاعلي</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap');
        body {
            font-family: 'Tajawal', sans-serif;
            background-color: #0f172a;
            color: #f1f5f9;
        }
        .canvas-container {
            background: radial-gradient(circle, #1e293b 0%, #0f172a 100%);
            border: 2px solid #334155;
            border-radius: 1rem;
            position: relative;
            overflow: hidden;
        }
        .tab-active {
            border-bottom: 4px solid #38bdf8;
            color: #38bdf8;
        }
        .control-panel {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(10px);
        }
    </style>
</head>
<body class="p-4 md:p-8">

    <header class="max-w-6xl mx-auto text-center mb-10">
        <h1 class="text-4xl font-bold text-sky-400 mb-4">مختبر ميكانيكا الكم الافتراضي</h1>
        <p class="text-slate-400 max-w-2xl mx-auto">
            استكشف عالم الجسيمات دون الذرية، من ازدواجية الموجة والجسيم إلى النفق الكمومي والتشابك.
        </p>
    </header>

    <main class="max-w-6xl mx-auto">
        <!-- Navigation Tabs -->
        <div class="flex flex-wrap justify-center gap-4 mb-8 border-b border-slate-700">
            <button onclick="switchTab('double-slit')" id="tab-double-slit" class="px-6 py-3 font-bold transition-all tab-active">الشق المزدوج</button>
            <button onclick="switchTab('tunneling')" id="tab-tunneling" class="px-6 py-3 font-bold transition-all text-slate-400 hover:text-white">النفق الكمومي</button>
            <button onclick="switchTab('uncertainty')" id="tab-uncertainty" class="px-6 py-3 font-bold transition-all text-slate-400 hover:text-white">مبدأ اللايقين</button>
            <button onclick="switchTab('entanglement')" id="tab-entanglement" class="px-6 py-3 font-bold transition-all text-slate-400 hover:text-white">التشابك الكمي</button>
        </div>

        <!-- Canvas Area -->
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
            <div class="lg:col-span-3">
                <div id="simulation-container" class="canvas-container h-[500px] w-full flex items-center justify-center">
                    <canvas id="mainCanvas"></canvas>
                </div>
                <div id="description-box" class="mt-4 p-4 bg-slate-800/50 rounded-lg border border-slate-700">
                    <h3 id="desc-title" class="text-xl font-bold text-sky-300 mb-2">تجربة الشق المزدوج</h3>
                    <p id="desc-text" class="text-slate-300 leading-relaxed">
                        توضح هذه التجربة "ازدواجية الموجة والجسيم". عندما لا نراقب الإلكترونات، تمر عبر الشقين كموجة وتتداخل لتكون نمطاً من الخطوط الساطعة والمظلمة. عند المراقبة، تسلك سلوك الجسيمات الكلاسيكية.
                    </p>
                </div>
            </div>

            <!-- Controls -->
            <div class="control-panel p-6 rounded-xl border border-slate-700 shadow-xl">
                <h3 class="text-lg font-bold mb-6 border-b border-slate-600 pb-2">لوحة التحكم</h3>
                
                <div id="controls-double-slit" class="space-y-6">
                    <label class="block">
                        <span class="text-sm text-slate-400">نمط العرض</span>
                        <select id="ds-mode" class="w-full mt-2 bg-slate-900 border border-slate-600 p-2 rounded" onchange="initDoubleSlit()">
                            <option value="wave">موجة (غير مراقب)</option>
                            <option value="particle">جسيم (مراقب)</option>
                        </select>
                    </label>
                    <button onclick="initDoubleSlit()" class="w-full bg-sky-600 hover:bg-sky-500 py-2 rounded font-bold transition">إعادة المحاكاة</button>
                </div>

                <div id="controls-tunneling" class="hidden space-y-6">
                    <label class="block">
                        <span class="text-sm text-slate-400">ارتفاع الحاجز الجهدي</span>
                        <input type="range" id="tunnel-height" class="w-full mt-2" min="50" max="250" value="150" oninput="initTunneling()">
                    </label>
                    <p class="text-xs text-slate-400 italic">لاحظ كيف تخرج بعض الجسيمات من الطرف الآخر رغم أن طاقتها أقل من الحاجز.</p>
                </div>

                <div id="controls-uncertainty" class="hidden space-y-6">
                    <label class="block">
                        <span class="text-sm text-slate-400">تضييق الحزمة (تحديد الموقع)</span>
                        <input type="range" id="uncert-width" class="w-full mt-2" min="5" max="100" value="50" oninput="initUncertainty()">
                    </label>
                    <div class="p-3 bg-red-900/20 border border-red-900/50 rounded text-sm">
                        كلما حددنا موقع الجسيم بدقة أكبر (تضييق الفتحة)، زاد تشتت زخمه (انتشار الحركة).
                    </div>
                </div>

                <div id="controls-entanglement" class="hidden space-y-6">
                    <button onclick="fireEntangled()" class="w-full bg-purple-600 hover:bg-purple-500 py-2 rounded font-bold transition">إطلاق جسيمين متشابكين</button>
                    <div class="text-sm text-slate-400">قياس حالة الجسيم الأول يحدد حالة الثاني فورياً بغض النظر عن المسافة.</div>
                </div>
            </div>
        </div>
    </main>

    <script>
        const canvas = document.getElementById('mainCanvas');
        const ctx = canvas.getContext('2d');
        let animationId;
        let currentTab = 'double-slit';

        // Resize handling
        function resize() {
            const container = document.getElementById('simulation-container');
            canvas.width = container.clientWidth;
            canvas.height = container.clientHeight;
            startSimulation();
        }

        window.addEventListener('resize', resize);
        window.onload = resize;

        function switchTab(tab) {
            currentTab = tab;
            // UI Updates
            document.querySelectorAll('[id^="tab-"]').forEach(el => el.classList.remove('tab-active', 'text-white'));
            document.querySelectorAll('[id^="tab-"]').forEach(el => el.classList.add('text-slate-400'));
            document.getElementById('tab-' + tab).classList.add('tab-active', 'text-white');
            
            document.querySelectorAll('[id^="controls-"]').forEach(el => el.classList.add('hidden'));
            document.getElementById('controls-' + tab).classList.remove('hidden');

            const descriptions = {
                'double-slit': {
                    title: 'تجربة الشق المزدوج',
                    text: 'توضح هذه التجربة "ازدواجية الموجة والجسيم". عندما لا نراقب الإلكترونات، تمر عبر الشقين كموجة وتتداخل لتكون نمطاً من الخطوط الساطعة والمظلمة (تداخل بناء وهدام). عند وضع كاشف (مراقبة)، ينهار التراكب الكمي ويسلك الإلكترون سلوك الجسيم، فيختفي نمط التداخل.'
                },
                'tunneling': {
                    title: 'النفق الكمومي (Quantum Tunneling)',
                    text: 'في الميكانيكا الكلاسيكية، إذا لم يملك الجسيم طاقة كافية، لا يمكنه تجاوز الحاجز. لكن في ميكانيكا الكم، وبسبب الطبيعة الموجية (الدالة الموجية)، هناك احتمال ضئيل لوجود الجسيم خلف الحاجز، مما يسمح له بـ "العبور" من خلاله.'
                },
                'uncertainty': {
                    title: 'مبدأ اللايقين (Heisenberg Uncertainty)',
                    text: 'ينص المبدأ على أنه لا يمكن تحديد الموقع والزخم معاً بدقة متناهية. في هذه المحاكاة، عندما تضيق الفتحة لتحديد موقع الجسيم بدقة، تجبر الطبيعة الموجية الجسيم على الانتشار بزاوية أوسع، مما يجعل زخم الجسيم غير معروف بدقة أكبر.'
                },
                'entanglement': {
                    title: 'التشابك الكمي (Quantum Entanglement)',
                    text: 'عندما يتشابك جسيمان، يصبحان نظاماً واحداً. إذا قمنا بقياس "لف" (Spin) جسيم واحد وجدناه "للأعلى"، سيكتسب الجسيم الآخر فوراً حالة "للأسفل"، حتى لو كان في الطرف الآخر من الكون. هذا ما وصفه أينشتاين بـ "الفعل الشبحي عن بعد".'
                }
            };

            document.getElementById('desc-title').innerText = descriptions[tab].title;
            document.getElementById('desc-text').innerText = descriptions[tab].text;

            startSimulation();
        }

        function startSimulation() {
            if (animationId) cancelAnimationFrame(animationId);
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            if (currentTab === 'double-slit') initDoubleSlit();
            if (currentTab === 'tunneling') initTunneling();
            if (currentTab === 'uncertainty') initUncertainty();
            if (currentTab === 'entanglement') initEntanglement();
        }

        // --- Double Slit Simulation ---
        let particles = [];
        function initDoubleSlit() {
            particles = [];
            const mode = document.getElementById('ds-mode').value;
            function animate() {
                ctx.fillStyle = 'rgba(15, 23, 42, 0.1)';
                ctx.fillRect(0, 0, canvas.width, canvas.height);

                // Draw Wall
                ctx.fillStyle = '#475569';
                ctx.fillRect(canvas.width * 0.3, 0, 10, canvas.height/2 - 20);
                ctx.fillRect(canvas.width * 0.3, canvas.height/2 - 10, 10, 20);
                ctx.fillRect(canvas.width * 0.3, canvas.height/2 + 20, 10, canvas.height/2 - 20);

                if (Math.random() > 0.8) {
                    particles.push({
                        x: 50,
                        y: canvas.height / 2 + (Math.random() * 40 - 20),
                        vx: 4,
                        vy: (Math.random() - 0.5) * 0.5,
                        passed: false,
                        color: mode === 'wave' ? '#38bdf8' : '#fbbf24'
                    });
                }

                particles.forEach((p, index) => {
                    p.x += p.vx;
                    p.y += p.vy;

                    if (!p.passed && p.x > canvas.width * 0.3) {
                        p.passed = true;
                        if (mode === 'wave') {
                            // Quantum interference probability
                            const angle = (Math.sin(p.y * 0.05) * 0.8);
                            p.vy = angle * 2;
                        } else {
                            // Particle behavior
                            p.vy = (Math.random() - 0.5) * 1;
                        }
                    }

                    ctx.beginPath();
                    ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
                    ctx.fillStyle = p.color;
                    ctx.fill();

                    if (p.x > canvas.width) particles.splice(index, 1);
                });

                // Interference Pattern (Visual aid)
                if (mode === 'wave') {
                    for(let i=0; i<canvas.height; i+=5) {
                        let intensity = Math.pow(Math.cos(i * 0.05), 2);
                        ctx.fillStyle = `rgba(56, 189, 248, ${intensity * 0.3})`;
                        ctx.fillRect(canvas.width - 20, i, 20, 5);
                    }
                }

                animationId = requestAnimationFrame(animate);
            }
            animate();
        }

        // --- Tunneling Simulation ---
        function initTunneling() {
            particles = [];
            const barrierH = parseInt(document.getElementById('tunnel-height').value);
            
            function animate() {
                ctx.fillStyle = '#0f172a';
                ctx.fillRect(0, 0, canvas.width, canvas.height);

                // Draw Barrier
                ctx.strokeStyle = '#ef4444';
                ctx.lineWidth = 4;
                ctx.beginPath();
                ctx.moveTo(canvas.width/2, canvas.height/2 + 100);
                ctx.lineTo(canvas.width/2, canvas.height/2 - barrierH);
                ctx.stroke();
                ctx.fillStyle = 'rgba(239, 68, 68, 0.2)';
                ctx.fillRect(canvas.width/2 - 5, canvas.height/2 - barrierH, 10, 100 + barrierH);

                if (Math.random() > 0.9) {
                    particles.push({
                        x: 50,
                        y: canvas.height/2,
                        vx: 3,
                        tunnelled: false
                    });
                }

                particles.forEach((p, index) => {
                    p.x += p.vx;
                    
                    // Probability of tunneling
                    if (p.x >= canvas.width/2 - 5 && p.x <= canvas.width/2 + 5) {
                        let tunnelProb = 1 - (barrierH / 300);
                        if (Math.random() > tunnelProb) {
                            p.vx = -3; // Bounce back
                        } else {
                            p.tunnelled = true; // Tunnel through
                        }
                    }

                    ctx.beginPath();
                    ctx.arc(p.x, p.y, 4, 0, Math.PI * 2);
                    ctx.fillStyle = p.tunnelled ? '#4ade80' : '#f87171';
                    ctx.shadowBlur = p.tunnelled ? 10 : 0;
                    ctx.shadowColor = '#4ade80';
                    ctx.fill();
                    ctx.shadowBlur = 0;

                    if (p.x > canvas.width || p.x < 0) particles.splice(index, 1);
                });

                animationId = requestAnimationFrame(animate);
            }
            animate();
        }

        // --- Uncertainty Simulation ---
        function initUncertainty() {
            particles = [];
            function animate() {
                const slitWidth = parseInt(document.getElementById('uncert-width').value);
                ctx.fillStyle = 'rgba(15, 23, 42, 0.2)';
                ctx.fillRect(0, 0, canvas.width, canvas.height);

                // Draw Slit
                ctx.fillStyle = '#475569';
                ctx.fillRect(100, 0, 15, canvas.height/2 - slitWidth/2);
                ctx.fillRect(100, canvas.height/2 + slitWidth/2, 15, canvas.height/2);

                if (Math.random() > 0.7) {
                    particles.push({
                        x: 0,
                        y: canvas.height/2 + (Math.random() * slitWidth - slitWidth/2),
                        vx: 4,
                        vy: 0,
                        spread: (100 - slitWidth) / 20 // Uncertainty relation
                    });
                }

                particles.forEach((p, index) => {
                    p.x += p.vx;
                    if (p.x > 115) {
                        p.y += p.vy;
                        if (p.vy === 0) p.vy = (Math.random() - 0.5) * p.spread;
                    }

                    ctx.beginPath();
                    ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
                    ctx.fillStyle = '#a78bfa';
                    ctx.fill();

                    if (p.x > canvas.width) particles.splice(index, 1);
                });

                animationId = requestAnimationFrame(animate);
            }
            animate();
        }

        // --- Entanglement Simulation ---
        let entangledPairs = [];
        function initEntanglement() {
            entangledPairs = [];
            function animate() {
                ctx.fillStyle = '#0f172a';
                ctx.fillRect(0, 0, canvas.width, canvas.height);

                ctx.setLineDash([5, 5]);
                ctx.strokeStyle = '#334155';
                ctx.beginPath();
                ctx.moveTo(canvas.width/2, 0);
                ctx.lineTo(canvas.width/2, canvas.height);
                ctx.stroke();
                ctx.setLineDash([]);

                entangledPairs.forEach((pair, index) => {
                    pair.p1.x -= 2;
                    pair.p2.x += 2;

                    // Connection line
                    ctx.strokeStyle = `rgba(168, 85, 247, ${pair.alpha})`;
                    ctx.beginPath();
                    ctx.moveTo(pair.p1.x, pair.p1.y);
                    ctx.lineTo(pair.p2.x, pair.p2.y);
                    ctx.stroke();

                    // Draw particles
                    [pair.p1, pair.p2].forEach(p => {
                        ctx.beginPath();
                        ctx.arc(p.x, p.y, 6, 0, Math.PI * 2);
                        ctx.fillStyle = p.state === 'up' ? '#f472b6' : '#2dd4bf';
                        ctx.fill();
                        
                        // Spin indicator
                        ctx.fillStyle = 'white';
                        ctx.font = '10px Arial';
                        ctx.fillText(p.state === 'up' ? '↑' : '↓', p.x - 3, p.y + 4);
                    });

                    if (pair.p1.x < 0) entangledPairs.splice(index, 1);
                });

                animationId = requestAnimationFrame(animate);
            }
            animate();
        }

        function fireEntangled() {
            const state1 = Math.random() > 0.5 ? 'up' : 'down';
            const state2 = state1 === 'up' ? 'down' : 'up';
            entangledPairs.push({
                p1: { x: canvas.width/2, y: canvas.height/2, state: state1 },
                p2: { x: canvas.width/2, y: canvas.height/2, state: state2 },
                alpha: 0.5
            });
        }

    </script>
</body>
</html>
